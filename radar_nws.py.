class handler(BaseHTTPRequestHandler):
    def do_GET(self):
        try:
            # SCAN THE US FOR HIGH-VALUE TARGETS
            headers = {'User-Agent': 'EmpireAI-Pulse'}
            response = requests.get('https://api.weather.gov/alerts/active', headers=headers)
            alerts = response.json().get('features', [])
            
            pings = 0
            # WE ONLY CARE ABOUT ROOF-DAMAGING EVENTS
            targets = ["Tornado Warning", "Severe Thunderstorm Warning", "High Wind Warning"]

            for a in alerts:
                p = a['properties']
                if p['event'] in targets:
                    # A. LOCK DATA IN THE VAULT
                    supabase.table("radar_targets").insert({
                        "storm_event": p['event'],
                        "address": p['areaDesc'],
                        "campaign_status": "NEW"
                    }).execute()
                    
                    # B. FORMAT THE BROADCAST
                    msg = f"🚨 **EMPIRE STRIKE**: {p['event']}\n📍 **Location**: {p['areaDesc']}\n[OPEN HUD](https://empire-revenue-pulse.vercel.app)"
                    
                    # C. DISCORD BLAST
                    requests.post(DISCORD_URL, json={"content": msg})
                    
                    # D. TELEGRAM BLAST
                    tg_api = f"https://api.telegram.org/bot{TG_TOKEN}/sendMessage"
                    requests.post(tg_api, data={"chat_id": TG_CHAT_ID, "text": msg})
                    
                    pings += 1

            self.send_response(200)
            self.send_header('Content-type', 'application/json')
            self.end_headers()
            self.wfile.write(json.dumps({"status": "Online", "strikes_found": pings}).encode())
            
        except Exception as e:
            self.send_response(500)
            self.end_headers()
            self.wfile.write(str(e).encode())
