from http.server import BaseHTTPRequestHandler
import json
from supabase import create_client

SB_URL = "https://clmuzwbagzcyymfqswbn.supabase.co"
SB_KEY = "sb_publishable_fFVaZgkLz7v8kQMtSJ1VKg_okCuKxyx"
supabase = create_client(SB_URL, SB_KEY)

class handler(BaseHTTPRequestHandler):
    def do_GET(self):
        new_leads = supabase.table("radar_targets").select("*").eq("campaign_status", "NEW").execute()
        
        for lead in new_leads.data:
            # ALI LOGIC
            supabase.table("forged_reports").insert({
                "target_id": lead['id'],
                "business_name": lead['business_name'],
                "damage_score": 90,
                "forged_summary": "High-probability commercial roof damage detected. Initiate outreach."
            }).execute()

            supabase.table("radar_targets").update({"campaign_status": "REPORT FORGED"}).eq("id", lead['id']).execute()

        self.send_response(200)
        self.end_headers()
        self.wfile.write(json.dumps({"status": "Success"}).encode())
